{
    "name": "top-bolsa-app",
    "version": "1.0.1",
    "main": "index.ts",
    "scripts": {
        "start": "expo start",
        "android": "expo run:android",
        "ios": "expo run:ios",
        "web": "expo start --web",
        "lint": "eslint . --ext .js,.ts,.tsx",
        "lint:fix": "npm run lint -- --fix",
        "format": "prettier --write .",
        "format:check": "prettier --check .",
        "typecheck": "tsc --noEmit",
        "build:android:preview": "npx eas-cli build -p android --profile preview",
        "build:android:production": "npx eas-cli build -p android --profile production",
        "prepare": "husky",
        "postinstall": "patch-package",
        "check:supabase-schema": "node scripts/check-supabase-schema-parity.mjs",
        "verify": "npm run lint && npm run format:check && npm run test && npm run typecheck && npm run check:supabase-schema",
        "test": "vitest run",
        "test:watch": "vitest"
    },
    "dependencies": {
        "@react-native-async-storage/async-storage": "^3.0.1",
        "@react-navigation/native": "^7.1.30",
        "@react-navigation/native-stack": "^7.14.1",
        "@supabase/supabase-js": "^2.97.0",
        "@tanstack/react-query": "^5.90.21",
        "expo": "~54.0.33",
        "expo-haptics": "~15.0.8",
        "expo-status-bar": "~3.0.9",
        "lucide-react-native": "^0.575.0",
        "nativewind": "^4.1.23",
        "react": "19.1.0",
        "react-native": "0.81.5",
        "react-native-gesture-handler": "~2.28.0",
        "react-native-reanimated": "~4.1.1",
        "react-native-safe-area-context": "~5.6.0",
        "react-native-screens": "~4.16.0",
        "react-native-svg": "15.12.1",
        "react-native-url-polyfill": "^3.0.0",
        "react-native-wagmi-charts": "^2.9.1",
        "react-native-worklets": "0.5.1"
    },
    "devDependencies": {
        "@eslint/js": "^9.39.4",
        "@tanstack/eslint-plugin-query": "^5.95.2",
        "@types/react": "~19.1.0",
        "babel-plugin-module-resolver": "^5.0.3",
        "babel-preset-expo": "^54.0.10",
        "eslint": "^9.39.4",
        "eslint-config-prettier": "^10.1.8",
        "eslint-import-resolver-typescript": "^4.4.4",
        "eslint-plugin-import": "^2.32.0",
        "eslint-plugin-react": "^7.37.5",
        "eslint-plugin-react-hooks": "^7.0.1",
        "eslint-plugin-react-native": "^5.0.0",
        "globals": "^17.4.0",
        "husky": "^9.1.7",
        "lint-staged": "^16.4.0",
        "patch-package": "^8.0.1",
        "prettier": "^3.8.1",
        "tailwindcss": "^3.3.2",
        "typescript": "~5.9.2",
        "typescript-eslint": "^8.57.2",
        "vite-tsconfig-paths": "^6.1.1",
        "vitest": "^4.0.18"
    },
    "lint-staged": {
        "*.{js,ts,tsx,json,md,yml,yaml}": [
            "prettier --write"
        ],
        "src/**/*.{ts,tsx}": [
            "eslint --fix"
        ]
    },
    "private": true
}
